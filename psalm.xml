<?xml version="1.0"?>
<psalm
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config file://./tools/03_psalm/vendor/vimeo/psalm/config.xsd"
    errorLevel="2"
    rememberPropertyAssignmentsAfterCall="false"
    findUnusedBaselineEntry="true"
    findUnusedCode="false"
>
    <projectFiles>
        <directory name="src/" />
        <directory name="tests/" />

        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>

    <plugins>
        <pluginClass class="Psalm\SymfonyPsalmPlugin\Plugin" />
        <pluginClass class="Psalm\PhpUnitPlugin\Plugin" />
        <pluginClass class="Weirdan\DoctrinePsalmPlugin\Plugin" />
    </plugins>

    <issueHandlers>
        <ArgumentTypeCoercion>
            <errorLevel type="suppress">
                <directory name="tests/Integration" />
            </errorLevel>
        </ArgumentTypeCoercion>

        <PossiblyInvalidArgument>
            <errorLevel type="suppress">
                <!-- Entity provider payload contains nullable values for generic base assertions -->
                <file name="tests/Integration/TestCase/EntityTestCase.php" />
                <!-- Entity test provider can emit null values in shared payload structure -->
                <file name="tests/Integration/Entity/DateDimensionTest.php" />
                <!-- Entity test provider can emit null values in shared payload structure -->
                <file name="tests/Integration/Entity/LogLoginFailureTest.php" />
                <!-- Entity test provider can emit null values in shared payload structure -->
                <file name="tests/Integration/Entity/LogLoginTest.php" />
                <!-- Entity test provider can emit null values in shared payload structure -->
                <file name="tests/Integration/Entity/LogRequestTest.php" />
                <!-- PHPUnit mock-builder typing causes nullable provider payload in resolver tests -->
                <file name="tests/Integration/ValueResolver/RestDtoValueResolverTest.php" />
                <!-- Reflection-driven data providers allow nullable payloads for integrity assertions -->
                <file name="tests/Unit/IntegrityTest.php" />
            </errorLevel>
        </PossiblyInvalidArgument>

        <ClassMustBeFinal>
            <errorLevel type="suppress">
                <directory name="src" />
            </errorLevel>
        </ClassMustBeFinal>

        <ImplicitToStringCast>
            <errorLevel type="suppress">
                <directory name="tests/E2E" />
            </errorLevel>
        </ImplicitToStringCast>

        <PropertyNotSetInConstructor>
            <errorLevel type="suppress">
                <file name="src/Validator/Constraints/EntityReferenceExists.php" />
                <referencedProperty name="App\Entity\UserGroup::$role" />
                <referencedProperty name="App\Rest\RestResource::$validator" />
            </errorLevel>
        </PropertyNotSetInConstructor>
    </issueHandlers>
</psalm>
